# Copiar este archivo como .env y completar los valores reales
# cp .env.example .env

# ---------------------------------------------------------------
# Groq API — obtener clave en https://console.groq.com
# ---------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------
# Embedding — modelo multilingue ES/EN/ZH (se descarga automaticamente)
# EMBEDDING_DEVICE: "cuda" si tienes GPU NVIDIA, "cpu" si no
# ---------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu

# ---------------------------------------------------------------
# FAISS — ruta donde se guarda/carga el indice vectorial
# ---------------------------------------------------------------
FAISS_STORE_PATH=./faiss_store

# ---------------------------------------------------------------
# Datasets — rutas relativas desde la raiz del proyecto
# Descargar desde:
#   MedMCQA:      https://huggingface.co/datasets/openlifescienceai/medmcqa
#   MedQA:        https://github.com/jind11/MedQA
#   Multiclinsum: https://huggingface.co/datasets/vgaraujov/multiclinsum
# ---------------------------------------------------------------
DATASET_MEDMCQA_PATH=./datasets/data
DATASET_MEDQA_PATH=./datasets/data_clean/data_clean
DATASET_MULTICLINSUM_PATH=./datasets/multiclinsum_large-scale_train_es/multiclinsum_large-scale_train_es

# ---------------------------------------------------------------
# RAG
# ---------------------------------------------------------------
RAG_TOP_K=5

# ---------------------------------------------------------------
# App
# ---------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# Telegram Bot — token del bot creado con @BotFather
# ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------
# Status Check Scheduler — envio periodico de check de estado
# STATUS_CHECK_CHAT_ID: ID numerico del chat donde enviar el mensaje
#   Para obtenerlo: envia un mensaje al bot y visita
#   https://api.telegram.org/bot<TU_TOKEN>/getUpdates
# STATUS_CHECK_INTERVAL_MINUTES: minutos entre cada envio (default: 10)
# STATUS_CHECK_MESSAGE: texto del mensaje (soporta Markdown)
# ---------------------------------------------------------------
STATUS_CHECK_CHAT_ID=
STATUS_CHECK_INTERVAL_MINUTES=10
STATUS_CHECK_MESSAGE=🩺 *Check de estado* — ¿Cómo te encuentras hoy? Cuéntame cualquier molestia o duda que tengas.
